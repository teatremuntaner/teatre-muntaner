---
// Calendario propio del Teatre Muntaner (sustituye al iframe de styledcalendar).
// Rejilla de mes con la marca del teatro: los días con función se marcan con el
// color del cartel; al pulsar un día se muestran sus funciones + botón Comprar.
// Se alimenta de los mismos datos de cada espectáculo (fechas + hora + entradas).
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const MONTHS = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const WD = ['L', 'M', 'X', 'J', 'V', 'S', 'D'];

const today = new Date();
today.setHours(0, 0, 0, 0);
const pad = (n: number) => String(n).padStart(2, '0');
const iso = (y: number, m: number, d: number) => `${y}-${pad(m + 1)}-${pad(d)}`;
const todayStr = iso(today.getFullYear(), today.getMonth(), today.getDate());

const shows = await getCollection('espectaculos', ({ data }) => !data.draft && !data.unlisted);

type Fn = { date: string; time: string; title: string; accent: string; ink: string; poster: string; href: string; buy: string; alarm: boolean };
const fns: Fn[] = [];
for (const s of shows) {
  const d = s.data;
  const href = d.externalUrl ?? `${base}espectaculos/${s.id}/`; // "Ver más" → ficha (o landing)
  const buy = d.ticketUrl ?? null;                              // compra real (o null)
  for (const dt of d.dates) {
    if (dt.date >= todayStr) {
      fns.push({
        date: dt.date, time: dt.time ?? '',
        title: d.title, accent: d.accent ?? '#bd221f', ink: d.accentInk ?? '#ffffff',
        poster: d.poster.src, href, buy, alarm: !!d.ticketAlarm,
      });
    }
  }
}
fns.sort((a, b) => (a.date + (a.time || '99')).localeCompare(b.date + (b.time || '99')));

// Meses a mostrar: del mes actual al del último pase.
const months: { y: number; m: number }[] = [];
{
  let y = today.getFullYear(), m = today.getMonth();
  const last = fns.length ? fns[fns.length - 1].date : todayStr;
  const ly = +last.slice(0, 4), lm = +last.slice(5, 7) - 1;
  while (y < ly || (y === ly && m <= lm)) {
    months.push({ y, m });
    if (++m > 11) { m = 0; y++; }
  }
  if (!months.length) months.push({ y: today.getFullYear(), m: today.getMonth() });
}

const fnsByDate = new Map<string, Fn[]>();
for (const f of fns) (fnsByDate.get(f.date) ?? fnsByDate.set(f.date, []).get(f.date)!).push(f);

const matrix = (y: number, m: number) => {
  const offset = (new Date(y, m, 1).getDay() + 6) % 7; // lunes primero
  const days = new Date(y, m + 1, 0).getDate();
  const cells: ({ dnum: number; ds: string } | null)[] = Array(offset).fill(null);
  for (let dnum = 1; dnum <= days; dnum++) cells.push({ dnum, ds: iso(y, m, dnum) });
  return cells;
};

const selDate = fns.length ? fns[0].date : null;
const startIdx = Math.max(0, months.findIndex((mm) => selDate && mm.y === +selDate.slice(0, 4) && mm.m === +selDate.slice(5, 7) - 1));
const labels = months.map((mm) => `${MONTHS[mm.m]} ${mm.y}`);
---

<section class="section calend" id="calendario">
  <div class="wrap">
    <header class="section__head reveal">
      <p class="kicker kicker--blue">Agenda</p>
      <h2 class="section__title">Calendario de funciones</h2>
    </header>

    <div class="cal reveal">
      <div class="cal__head">
        <button class="cal__nav" data-nav="-1" type="button" aria-label="Mes anterior">‹</button>
        <h3 class="cal__month" id="calMonth">{labels[startIdx]}</h3>
        <button class="cal__nav" data-nav="1" type="button" aria-label="Mes siguiente">›</button>
      </div>

      <div class="cal__grid-wrap">
        <div class="cal__weekdays">{WD.map((w) => <span>{w}</span>)}</div>
        {months.map((mm, idx) => (
          <div class="cal__grid" data-month={idx} hidden={idx !== startIdx}>
            {matrix(mm.y, mm.m).map((cell) => {
              if (!cell) return <span class="cal__cell cal__cell--empty" aria-hidden="true"></span>;
              const dayFns = fnsByDate.get(cell.ds) ?? [];
              const has = dayFns.length > 0;
              // Un chip por espectáculo distinto del día (no repetimos el mismo show)
              const chips = [];
              if (has) {
                const seen = new Set();
                for (const f of dayFns) if (!seen.has(f.title)) { seen.add(f.title); chips.push({ title: f.title, accent: f.accent }); }
              }
              const shown = chips.slice(0, 2);
              const more = chips.length - shown.length;
              const label = has ? `${cell.dnum}: ${chips.map((c) => c.title).join(', ')}` : String(cell.dnum);
              return (
                <button
                  class={`cal__cell${has ? ' has-fn' : ''}${cell.ds === todayStr ? ' is-today' : ''}`}
                  data-date={cell.ds}
                  disabled={!has}
                  type="button"
                  style={has ? `--d-accent:${dayFns[0].accent}` : ''}
                  aria-label={label}
                >
                  <span class="cal__num">{cell.dnum}</span>
                  {has && (
                    <span class="cal__chips">
                      {shown.map((c) => <span class="cal__chip" style={`--c:${c.accent}`}>{c.title}</span>)}
                      {more > 0 && <span class="cal__chip cal__chip--more">+{more}</span>}
                    </span>
                  )}
                </button>
              );
            })}
          </div>
        ))}
      </div>

      <div class="cal__detail" id="calDetail" aria-live="polite"></div>
    </div>
  </div>

  <script type="application/json" id="cal-data" set:html={JSON.stringify({ fns, labels, startIdx, selDate })}></script>

  <script>
    const raw = document.getElementById('cal-data');
    const data = JSON.parse(raw?.textContent || '{}');
    const fns = data.fns || [];
    const labels = data.labels || [];
    const grids = Array.from(document.querySelectorAll('.cal__grid')) as HTMLElement[];
    const monthEl = document.getElementById('calMonth');
    const detail = document.getElementById('calDetail');
    const navs = Array.from(document.querySelectorAll('[data-nav]')) as HTMLButtonElement[];
    let active = data.startIdx || 0;

    const WD = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
    const MO = ['ene', 'feb', 'mar', 'abr', 'may', 'jun', 'jul', 'ago', 'sep', 'oct', 'nov', 'dic'];
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    function showMonth(i) {
      active = Math.max(0, Math.min(grids.length - 1, i));
      grids.forEach((g, idx) => (g.hidden = idx !== active));
      if (monthEl) monthEl.textContent = labels[active] || '';
      navs.forEach((b) => {
        const dir = Number(b.dataset.nav);
        b.disabled = active + dir < 0 || active + dir > grids.length - 1;
      });
    }
    navs.forEach((b) => b.addEventListener('click', () => showMonth(active + Number(b.dataset.nav))));

    function renderDetail(ds) {
      const list = fns.filter((f) => f.date === ds);
      if (!detail) return;
      if (!list.length) { detail.innerHTML = ''; return; }
      const d = new Date(ds + 'T00:00:00');
      const head = `${WD[d.getDay()]} ${d.getDate()} ${MO[d.getMonth()]}`;
      detail.innerHTML =
        `<p class="cal__detail-day">${head}</p>` +
        list.map((f) => {
          const buyExt = f.buy && String(f.buy).startsWith('http');
          let buyBtn = '';
          if (f.alarm) buyBtn = `<a class="cal__fn-buy" href="${esc(f.href)}">Avísame</a>`;
          else if (f.buy) buyBtn = `<a class="cal__fn-buy" href="${esc(f.buy)}"${buyExt ? ' target="_blank" rel="noopener"' : ''}>Comprar</a>`;
          return `<div class="cal__fn" style="--d-accent:${esc(f.accent)};--d-ink:${esc(f.ink)}">
              <a class="cal__fn-poster" href="${esc(f.href)}"><img src="${esc(f.poster)}" alt="Cartel de ${esc(f.title)}" loading="lazy" /></a>
              <div class="cal__fn-info">
                <a class="cal__fn-title" href="${esc(f.href)}">${esc(f.title)}</a>
                ${f.time ? `<span class="cal__fn-time">🕘 ${esc(f.time)}</span>` : ''}
              </div>
              <div class="cal__fn-actions">
                <a class="cal__fn-more" href="${esc(f.href)}">Ver más</a>
                ${buyBtn}
              </div>
            </div>`;
        }).join('');
    }

    function selectCell(cell) {
      document.querySelectorAll('.cal__cell.is-sel').forEach((x) => x.classList.remove('is-sel'));
      cell.classList.add('is-sel');
      renderDetail(cell.dataset.date);
    }
    document.querySelectorAll('.cal__cell.has-fn').forEach((c) =>
      c.addEventListener('click', () => selectCell(c)),
    );

    showMonth(active);
    if (data.selDate) {
      const sel = document.querySelector(`.cal__cell[data-date="${data.selDate}"]`);
      if (sel) selectCell(sel);
    }
  </script>
</section>

<style>
  /* La sección reutiliza .section__head/.kicker/.section__title, pero esos
     estilos viven en el <style> scoped de index.astro y NO llegan al componente.
     Los redefinimos aquí para que la cabecera quede como el resto del sitio. */
  .calend { padding: clamp(44px, 6vw, 92px) 0; background: linear-gradient(180deg, var(--ink) 0%, var(--ink-soft) 100%); }
  .calend .section__head { margin-bottom: clamp(22px, 3vw, 34px); }
  .calend .kicker { font-family: var(--f-display); font-size: 13px; letter-spacing: 0.26em; text-transform: uppercase; color: var(--c-wine); font-weight: 700; margin: 0 0 14px; }
  .calend .section__title { font-family: var(--f-title); font-weight: 600; font-size: clamp(34px, 5.5vw, 68px); text-transform: uppercase; line-height: 1; }
  .cal {
    position: relative; background: var(--ink-soft);
    border: 1px solid var(--line); border-radius: 16px;
    padding: clamp(16px, 2.4vw, 26px);
    box-shadow: 0 30px 70px -40px rgba(42, 20, 16, 0.5);
    max-width: 960px; margin: 0;
  }
  .cal::before {
    content: ""; position: absolute; top: 0; left: 24px; right: 24px; height: 3px; border-radius: 0 0 3px 3px;
    background: linear-gradient(90deg, var(--c-gold), var(--c-red) 50%, var(--c-gold));
  }
  .cal__head { display: flex; align-items: center; justify-content: center; gap: 22px; margin-bottom: 18px; }
  .cal__month {
    font-family: var(--f-display); font-size: clamp(22px, 3.5vw, 30px); text-transform: uppercase;
    letter-spacing: 0.04em; min-width: 8.5em; text-align: center; color: var(--paper);
  }
  .cal__nav {
    width: 42px; height: 42px; border-radius: 50%; border: 1px solid var(--line);
    background: transparent; color: var(--paper); font-size: 22px; line-height: 1;
    display: grid; place-items: center; transition: background .2s, border-color .2s, color .2s, opacity .2s;
  }
  .cal__nav:hover:not(:disabled) { border-color: var(--c-red); color: var(--c-red); background: rgba(189, 34, 31, 0.06); }
  .cal__nav:disabled { opacity: 0.28; cursor: default; }

  .cal__weekdays { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 6px; margin-bottom: 8px; }
  .cal__weekdays span {
    text-align: center; font-family: var(--f-display); font-size: 12px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--paper-faint); font-weight: 600;
  }
  .cal__grid { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)); gap: 6px; }
  .cal__grid[hidden] { display: none; }
  /* Casilla: compacta. Las semanas vacías quedan en filas bajas; las que tienen
     función crecen con sus chips → densidad donde hay info, aire donde no. */
  .cal__cell {
    position: relative; min-height: 40px; border: 1px solid transparent; border-radius: 9px;
    background: transparent; display: flex; flex-direction: column; align-items: stretch; gap: 4px;
    padding: 6px 7px; text-align: left;
    font-family: var(--f-display); font-size: 14px; color: var(--paper-faint);
    transition: background .18s, border-color .18s, color .18s, transform .12s;
  }
  .cal__cell--empty { border: 0; min-height: 0; }
  .cal__num { line-height: 1; }
  .cal__cell.is-today { box-shadow: inset 0 0 0 1px var(--line); }
  .cal__cell.is-today .cal__num { color: var(--c-red); font-weight: 700; }
  /* Días con función: tintados con el color del cartel, clicables */
  .cal__cell.has-fn {
    cursor: pointer; color: var(--paper);
    background: color-mix(in srgb, var(--d-accent) 9%, transparent);
    border-color: color-mix(in srgb, var(--d-accent) 26%, transparent);
  }
  .cal__cell.has-fn:hover { transform: translateY(-2px); background: color-mix(in srgb, var(--d-accent) 16%, transparent); border-color: var(--d-accent); }
  .cal__cell.is-sel { background: var(--d-accent); border-color: var(--d-accent); transform: none; }
  .cal__cell.is-sel .cal__num { color: #fff; }

  /* Chips con el nombre del espectáculo dentro de la casilla */
  .cal__chips { display: flex; flex-direction: column; gap: 3px; }
  .cal__chip {
    position: relative;
    font-family: var(--f-display); font-size: 10.5px; letter-spacing: 0.01em; line-height: 1.3;
    text-transform: uppercase; font-weight: 600;
    padding: 3px 6px 3px 13px; border-radius: 5px;
    /* Cajita NEUTRA (no un tinte del acento): un tinte del mismo tono pegado a la
       barra saturada creaba cromoestereopsis (efecto "cuatricromía descuadrada"). */
    background: #f2efe9; color: #2a1410;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  /* Barra de color ANCHA pero rodeada de neutro (keyline): al no lindar el color
     saturado con el fondo oscuro, se elimina el "vibrado" cromático. */
  .cal__chip::before {
    content: ""; position: absolute; left: 3px; top: 3px; bottom: 3px; width: 6px;
    border-radius: 2px; background: var(--c);
  }
  .cal__chip--more { background: transparent; color: var(--paper-faint); padding: 2px 3px; }
  .cal__chip--more::before { display: none; }
  .cal__cell.is-sel .cal__chip { background: rgba(255, 255, 255, 0.92); color: #1a0c08; }

  /* Panel del día seleccionado.
     OJO: el contenido del panel se inyecta por JS (innerHTML), así que el CSS
     scoped de Astro no le llega. Estas reglas van en :global() a propósito. */
  .cal__detail { margin-top: 20px; }
  .cal__detail:empty { display: none; }
  :global(.cal__detail-day) {
    font-family: var(--f-display); text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 14px; color: var(--c-red); margin: 0 0 12px; font-weight: 700;
  }
  :global(.cal__fn) {
    display: grid; grid-template-columns: 46px 1fr auto; align-items: center; gap: 14px;
    padding: 10px; border: 1px solid var(--line); border-radius: 12px; margin-bottom: 10px;
    border-left: 4px solid var(--d-accent); background: var(--ink);
  }
  :global(.cal__fn-poster) { display: block; width: 46px; border-radius: 6px; overflow: hidden; aspect-ratio: 2/3; }
  :global(.cal__fn-poster img) { width: 100%; height: 100%; object-fit: cover; }
  :global(.cal__fn-info) { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
  :global(.cal__fn-title) { font-family: var(--f-display); font-size: 17px; text-transform: uppercase; color: var(--paper); line-height: 1.1; }
  :global(.cal__fn-title:hover) { color: var(--c-red); }
  :global(.cal__fn-time) { font-size: 14px; color: var(--paper-dim); }
  :global(.cal__fn-actions) { display: flex; align-items: center; gap: 8px; }
  :global(.cal__fn-buy) {
    font-family: var(--f-display); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700;
    padding: 11px 18px; border-radius: 999px; background: var(--d-accent); color: var(--d-ink, #fff);
    white-space: nowrap; transition: filter .2s;
  }
  :global(.cal__fn-buy:hover) { filter: brightness(1.08); }
  /* "Ver más" fantasma → ficha del espectáculo (secundario, no compite con comprar) */
  :global(.cal__fn-more) {
    font-family: var(--f-display); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700;
    padding: 10px 16px; border-radius: 999px; white-space: nowrap;
    background: transparent; color: var(--paper); border: 1px solid var(--line);
    transition: border-color .2s, color .2s;
  }
  :global(.cal__fn-more:hover) { border-color: var(--d-accent); color: var(--d-accent); }

  @media (max-width: 560px) {
    .cal { padding: 14px 10px; }
    .cal__weekdays, .cal__grid { gap: 4px; }
    .cal__cell { border-radius: 8px; padding: 5px 4px; min-height: 36px; }
    /* En móvil el nombre no cabe: el chip se convierte en una barrita de color. */
    .cal__chip { font-size: 0; padding: 0; height: 4px; border-radius: 2px; background: var(--c); }
    .cal__chip::before { display: none; }
    .cal__chip--more { display: none; }
    .cal__cell.is-sel .cal__chip { background: rgba(255, 255, 255, 0.92); }
    :global(.cal__fn) { grid-template-columns: 46px 1fr; }
    :global(.cal__fn-actions) { grid-column: 1 / -1; }
    :global(.cal__fn-more), :global(.cal__fn-buy) { flex: 1; text-align: center; }
  }
</style>
