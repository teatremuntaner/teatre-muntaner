---
import Flag from './Flag.astro';
import { useT, langFromPath, equivalentPath, LANG_NAME } from '../i18n';

const path = Astro.url.pathname;
const lang = langFromPath(path);
const t = useT(lang);

// La raiz de cada idioma: "/" en castellano, "/ca/" en catalan.
const home = lang === 'ca' ? '/ca/' : import.meta.env.BASE_URL;
const items = [
  { href: home, label: t('nav.inicio') },
  { href: `${home}#cartelera`, label: t('nav.cartelera') },
  { href: `${home}#calendario`, label: t('nav.calendario') },
  { href: `${home}#galeria`, label: t('nav.galeria') },
  { href: `${home}alquiler/`, label: t('nav.alquiler') },
  { href: `${home}#contacto`, label: t('nav.contacto') },
];

// El selector de idioma ahora son ENLACES a la misma pagina en el otro idioma
// (antes lo hacia Weglot por JavaScript).
const hrefEs = equivalentPath(path, 'es');
const hrefCa = equivalentPath(path, 'ca');
---
<header class="site-header">
  <div class="wrap">
    <a class="site-header__logo" href={home} aria-label={`Teatre Muntaner · ${t('nav.inicio')}`}>
      <img src={`${import.meta.env.BASE_URL}logo-muntaner.png`} alt="Teatre Muntaner" />
    </a>
    <nav class="site-nav" aria-label={t('nav.principal')}>
      {items.map((i) => (
        <a
          href={i.href}
          aria-current={path === i.href ? 'page' : undefined}
        >{i.label}</a>
      ))}
    </nav>
    <div class="lang-switch" role="group" aria-label={t('nav.idioma')}>
      <a
        class:list={['lang-switch__btn', { 'is-active': lang === 'es' }]}
        href={hrefEs}
        hreflang="es"
        aria-label={LANG_NAME.es}
        title={LANG_NAME.es}
        aria-current={lang === 'es' ? 'true' : undefined}
      ><Flag lang="es" class="lang-switch__flag" /></a>
      <a
        class:list={['lang-switch__btn', { 'is-active': lang === 'ca' }]}
        href={hrefCa}
        hreflang="ca"
        aria-label={LANG_NAME.ca}
        title={LANG_NAME.ca}
        aria-current={lang === 'ca' ? 'true' : undefined}
      ><Flag lang="ca" class="lang-switch__flag" /></a>
    </div>
    <button class="site-nav__burger" aria-label={t('nav.abrirMenu')} aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  // Menú móvil
  const header = document.querySelector('.site-header');
  const burger = document.querySelector('.site-nav__burger');
  burger?.addEventListener('click', () => {
    const open = header?.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  document.querySelectorAll('.site-nav a').forEach((a) =>
    a.addEventListener('click', () => header?.classList.remove('is-open')),
  );

  // El selector de idioma ya no necesita JavaScript: son dos enlaces normales
  // a la misma pagina en el otro idioma, generados en el build.
</script>
