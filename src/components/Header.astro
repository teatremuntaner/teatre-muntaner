---
import Flag from './Flag.astro';
const base = import.meta.env.BASE_URL; // p. ej. "/V1/"
const items = [
  { href: base, label: 'Inicio' },
  { href: `${base}#cartelera`, label: 'Cartelera' },
  { href: `${base}#calendario`, label: 'Calendario' },
  { href: `${base}#galeria`, label: 'Galería' },
  { href: `${base}alquiler/`, label: 'Alquiler' },
  { href: `${base}#contacto`, label: 'Contacto' },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="wrap">
    <a class="site-header__logo" href={base} aria-label="Teatre Muntaner · Inicio">
      <img src={`${base}logo-muntaner.png`} alt="Teatre Muntaner" />
    </a>
    <nav class="site-nav" aria-label="Navegación principal">
      {items.map((i) => (
        <a
          href={i.href}
          class={i.accent ? 'is-accent' : undefined}
          aria-current={path === i.href ? 'page' : undefined}
        >{i.label}</a>
      ))}
    </nav>
    <div class="lang-switch" role="group" aria-label="Idioma">
      <button class="lang-switch__btn" data-lang="es" type="button" aria-label="Castellano" title="Castellano"><Flag lang="es" class="lang-switch__flag" /></button>
      <button class="lang-switch__btn" data-lang="ca" type="button" aria-label="Català" title="Català"><Flag lang="ca" class="lang-switch__flag" /></button>
    </div>
    <button class="site-nav__burger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  // Menú móvil
  const header = document.querySelector('.site-header');
  const burger = document.querySelector('.site-nav__burger');
  burger?.addEventListener('click', () => {
    const open = header?.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  document.querySelectorAll('.site-nav a').forEach((a) =>
    a.addEventListener('click', () => header?.classList.remove('is-open')),
  );

  // Selector de idioma (Weglot)
  (function () {
    const W = window as any;
    const btns = Array.from(document.querySelectorAll('.lang-switch__btn')) as HTMLElement[];
    if (!btns.length) return;
    const setActive = (lang: string) =>
      btns.forEach((b) => b.classList.toggle('is-active', b.dataset.lang === lang));
    btns.forEach((b) =>
      b.addEventListener('click', () => {
        if (W.Weglot && W.Weglot.switchTo) W.Weglot.switchTo(b.dataset.lang);
      }),
    );
    const hook = () => {
      if (!W.Weglot || !W.Weglot.on) return false;
      try {
        if (W.Weglot.getCurrentLang) setActive(W.Weglot.getCurrentLang());
        W.Weglot.on('languageChanged', (n: string) => setActive(n));
        W.Weglot.on('initialized', () => setActive(W.Weglot.getCurrentLang()));
      } catch (e) {}
      return true;
    };
    if (!hook()) {
      let n = 0;
      const t = setInterval(() => {
        if (hook() || ++n > 40) {
          clearInterval(t);
          // Si Weglot no está (p. ej. preview sin API key), ocultamos el selector
          if (!W.Weglot) { const sw = document.querySelector('.lang-switch') as HTMLElement; if (sw) sw.style.display = 'none'; }
        }
      }, 150);
    }
  })();
</script>
