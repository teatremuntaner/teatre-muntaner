---
import damasco from '../assets/venue/damasco.jpg';
import { useT, langFromPath, localePath } from '../i18n';

const year = new Date().getFullYear();
const lang = langFromPath(Astro.url.pathname);
const t = useT(lang);
// La raiz de cada idioma: "/" en castellano, "/ca/" en catalan.
const home = lang === 'ca' ? '/ca/' : import.meta.env.BASE_URL;
const footerBg = `linear-gradient(rgba(22,7,5,0.62), rgba(32,10,8,0.66)), url(${damasco.src}) center/cover`;
---
<footer class="site-footer site-footer--damask" style={`background:${footerBg}`}>
  <div class="site-footer__bar"></div>
  <div class="wrap">
    <div class="site-footer__cols">
      <div>
        <img src={`${import.meta.env.BASE_URL}logo-muntaner.png`} alt="Teatre Muntaner" style="height:58px;width:auto;margin-bottom:16px" />
        <p style="color:rgba(255,255,255,0.78);max-width:34ch">
          {t('footer.claim')}
        </p>
        <form name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/aviso-recibido/" style="margin-top:18px;max-width:320px">
          <input type="hidden" name="form-name" value="newsletter" />
          <p hidden><label>{t('footer.noRellenar')} <input name="bot-field" /></label></p>
          <label for="nl-email" style="display:block;font-family:var(--f-display);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:8px">{t('footer.newsletter')}</label>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <input id="nl-email" type="email" name="email" required placeholder="tu@email.com" style="flex:1 1 150px;min-width:0;padding:10px 12px;border-radius:8px;border:1px solid var(--line);background:#fff;color:var(--paper);font:inherit" />
            <button type="submit" class="btn btn--accent" style="padding:10px 16px">{t('footer.suscribirme')}</button>
          </div>
        </form>
      </div>
      <div>
        <h4>{t('footer.visitar')}</h4>
        <a href={`${home}#cartelera`}>{t('nav.cartelera')}</a>
        <a href={`${home}#calendario`}>{t('nav.calendario')}</a>
        <a href={`${home}#galeria`}>{t('nav.galeria')}</a>
        <a href={`${home}alquiler/`}>{t('nav.alquiler')}</a>
        <a href={`${home}#contacto`}>{t('nav.contacto')}</a>
      </div>
      <div>
        <h4>{t('footer.legal')}</h4>
        <a href={localePath(lang, '/aviso-legal/')}>{t('footer.avisoLegal')}</a>
        <a href={localePath(lang, '/politica-de-privacidad/')}>{t('footer.privacidad')}</a>
        <a href={localePath(lang, '/politica-de-cookies/')}>{t('footer.cookies')}</a>
        <a href="#" data-cc="show-preferences">{t('footer.configurarCookies')}</a>
      </div>
      <div>
        <h4>{t('footer.otrosTeatros')}</h4>
        <a href="https://teatrosofia.es" target="_blank" rel="noopener">Teatro Sofía</a>
        <a href="https://clapshow.es" target="_blank" rel="noopener">Clap Show</a>
        <h4 style="margin-top:22px">{t('footer.siguenos')}</h4>
        <a href="https://www.instagram.com/teatremuntaner/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.tiktok.com/@teatremuntaner" target="_blank" rel="noopener">TikTok</a>
        <a href="https://www.google.com/maps/place/Teatre+Muntaner/data=!4m7!3m6!1s0x12a4a31493c798f3:0x12a7966c424af8f6!8m2!3d41.3841653!4d2.1630793!16s%2Fg%2F11w9gjbjvn" target="_blank" rel="noopener">Google</a>
      </div>
    </div>
    <p class="site-footer__legal">© {year} La Muntaner Teatre, S.L. · Carrer de Muntaner 4, 08011 Barcelona · CIF B55438550 · info@teatremuntaner.com</p>
  </div>
</footer>
