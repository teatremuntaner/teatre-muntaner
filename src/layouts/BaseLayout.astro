---
import '../styles/global.css';
import '../styles/fx.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Capa de efectos visuales (tm-fx). false = desactivada para el público.
// Aun estando en false, se puede ver en vivo visitando la web con ?fx=1
// (y ?fx=0 para apagarla; la preferencia se recuerda en el navegador).
const FX_ENABLED = false;

interface Props {
  title: string;
  description?: string;
  accent?: string;        // color predominante del cartel
  accentInk?: string;     // color de texto legible sobre el acento
  titleFont?: string;     // nombre CSS de la tipografía del título (como la del cartel)
  titleFontUrl?: string;  // <link> de Google Fonts para esa tipografía
  image?: string;         // og:image
  bare?: boolean;         // landing de campaña: sin header/footer y siempre noindex
}
const {
  title,
  description = 'Teatre Muntaner · Carrer de Muntaner 4, Barcelona. La casa de la comedia: monólogos, magia, improvisación y teatro de humor.',
  accent = '#bd221f',
  accentInk = '#ffffff',
  titleFont,
  titleFontUrl,
  image,
  bare = false,
} = Astro.props;

const SITE = Astro.site ?? new URL('https://teatremuntaner.com');
const canonical = new URL(Astro.url.pathname, SITE).href;
const ogImage = image ?? new URL('og.jpg', SITE).href;
// Web de pruebas: noindex. Al pasar a teatremuntaner.com se pone INDEXABLE=true.
const indexable = process.env.INDEXABLE === 'true';
// Weglot (traducción automática al catalán). Latente hasta poner WEGLOT_API_KEY
// como variable de entorno en Netlify; entonces se inyecta el script solo.
const weglotKey = process.env.WEGLOT_API_KEY;

const bodyStyle =
  `--accent:${accent};--accent-ink:${accentInk};` +
  (titleFont ? `--f-title:'${titleFont}', var(--f-display);` : '');
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <!-- Capa de efectos (tm-fx): activa la clase antes de pintar para no parpadear -->
    <script is:inline define:vars={{ fxDefault: FX_ENABLED }}>
      (function () {
        try {
          var p = new URLSearchParams(location.search), v = p.get('fx');
          if (v === '1' || v === '0') localStorage.setItem('tm-fx', v);
          var s = localStorage.getItem('tm-fx');
          var on = s === null ? !!fxDefault : s === '1';
          if (on) document.documentElement.classList.add('tm-fx-on');
        } catch (e) {}
      })();
    </script>
    <!-- Consent Mode v2: por defecto DENEGADO hasta que el usuario acepte (RGPD/LSSI) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent','default',{
        ad_storage:'denied', ad_user_data:'denied', ad_personalization:'denied',
        analytics_storage:'denied', functionality_storage:'granted', security_storage:'granted',
        wait_for_update: 500
      });
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-TR52LK75');</script>
    <!-- End Google Tag Manager -->
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#14100e" />
    <title>{title} · Teatre Muntaner</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {(!indexable || bare) && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="64x64" href={`${import.meta.env.BASE_URL}favicon-64.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}favicon-180.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Reddit+Sans:wght@400;500;600;700&family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    {titleFontUrl && <link href={titleFontUrl} rel="stylesheet" />}
    <!-- Banner de cookies (vanilla-cookieconsent, gratis/open-source) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3.1.0/dist/cookieconsent.css" />
    <style is:inline>
      #cc-main {
        --cc-font-family: 'Reddit Sans', system-ui, sans-serif;
        --cc-btn-primary-bg: #bd221f; --cc-btn-primary-hover-bg: #9e1c19; --cc-btn-primary-border-color: #bd221f; --cc-btn-primary-hover-border-color: #9e1c19;
        --cc-btn-primary-color: #fff; --cc-btn-primary-hover-color: #fff;
        --cc-link-color: #bd221f; --cc-toggle-on-bg: #bd221f;
      }
    </style>
    {weglotKey && (
      <>
        <script is:inline src="https://cdn.weglot.com/weglot.min.js"></script>
        <script is:inline set:html={`Weglot.initialize({ api_key: '${weglotKey}' });`}></script>
      </>
    )}
    <meta property="og:title" content={`${title} · Teatre Muntaner`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Teatre Muntaner" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Teatre Muntaner`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body style={bodyStyle}>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TR52LK75" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    {!bare && <Header />}
    <main>
      <slot />
    </main>
    {!bare && <Footer />}

    <!-- Animación (gratis): GSAP + SplitText para los títulos. Sin smooth scroll. -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/SplitText.min.js"></script>

    <!-- Capa de efectos visuales (no hace nada salvo que tm-fx-on esté activa) -->
    <script>
      import '../scripts/fx';
    </script>

    <!-- Login del CMS para el personal (Netlify Identity; invisible si no está en Netlify) -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script define:vars={{ adminUrl: import.meta.env.BASE_URL + 'admin/' }}>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = adminUrl;
            });
          }
        });
      }
    </script>

    <!-- Consentimiento de cookies: banner + Consent Mode v2 (actualiza GTM al aceptar) -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3.1.0/dist/cookieconsent.umd.js"></script>
    <script is:inline>
      (function () {
        if (!window.CookieConsent) return;
        function syncConsent() {
          var analytics = CookieConsent.acceptedCategory('analytics');
          var marketing = CookieConsent.acceptedCategory('marketing');
          if (typeof gtag === 'function') {
            gtag('consent', 'update', {
              analytics_storage: analytics ? 'granted' : 'denied',
              ad_storage: marketing ? 'granted' : 'denied',
              ad_user_data: marketing ? 'granted' : 'denied',
              ad_personalization: marketing ? 'granted' : 'denied'
            });
          }
        }
        CookieConsent.run({
          guiOptions: {
            consentModal: { layout: 'box wide', position: 'bottom left' },
            preferencesModal: { layout: 'box' }
          },
          categories: { necessary: { enabled: true, readOnly: true }, analytics: {}, marketing: {} },
          onConsent: syncConsent,
          onChange: syncConsent,
          language: {
            default: 'es',
            translations: {
              es: {
                consentModal: {
                  title: 'Usamos cookies 🍪',
                  description: 'Utilizamos cookies propias y de terceros para analítica y para mejorar tu experiencia. Puedes aceptarlas, rechazarlas o configurarlas. Más información en nuestra <a href="/politica-de-cookies/">Política de cookies</a>.',
                  acceptAllBtn: 'Aceptar todo',
                  acceptNecessaryBtn: 'Rechazar',
                  showPreferencesBtn: 'Configurar'
                },
                preferencesModal: {
                  title: 'Preferencias de cookies',
                  acceptAllBtn: 'Aceptar todo',
                  acceptNecessaryBtn: 'Rechazar todo',
                  savePreferencesBtn: 'Guardar preferencias',
                  closeIconLabel: 'Cerrar',
                  sections: [
                    { title: 'Necesarias', description: 'Imprescindibles para el funcionamiento del sitio. Siempre activas.', linkedCategory: 'necessary' },
                    { title: 'Analíticas', description: 'Nos ayudan a entender cómo se usa la web (Google Analytics vía Tag Manager).', linkedCategory: 'analytics' },
                    { title: 'Marketing', description: 'Para medir campañas y mostrar contenido relevante.', linkedCategory: 'marketing' },
                    { title: 'Más información', description: 'Consulta nuestra <a href="/politica-de-cookies/">Política de cookies</a>.' }
                  ]
                }
              }
            }
          }
        });
        // Enlace "Configurar cookies" (footer u otros) para reabrir el panel
        document.addEventListener('click', function (e) {
          var t = e.target.closest && e.target.closest('[data-cc="show-preferences"]');
          if (t) { e.preventDefault(); CookieConsent.showPreferences(); }
        });
      })();
    </script>
  </body>
</html>
