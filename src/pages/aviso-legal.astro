---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useT, langFromPath } from '../i18n';

const lang = langFromPath(Astro.url.pathname);
const t = useT(lang);

// Nombres propios, dominio y correo: NO se traducen, entran como variable.
const TEATRO = 'Teatre Muntaner';
const WEB = 'teatremuntaner.com';
const EMAIL = 'info@teatremuntaner.com';
---
<BaseLayout title={t('legal.aviso.meta.titulo')} description={t('legal.aviso.meta.descripcion', { teatro: TEATRO })}>
  <article class="legal">
    <h1>{t('legal.aviso.titulo')}</h1>
    <h2>{t('legal.aviso.subtitulo')}</h2>
    <p>{t('legal.aviso.partes.titulo')}</p>
    <p>{t('legal.aviso.partes.comprador')}</p>
    <p>{t('legal.aviso.partes.organizador')}</p>
    <p>{t('legal.aviso.partes.agente')}</p>
    <p>{t('legal.aviso.datos.promotor')}: LA MUNTANER TEATRE SL</p>
    <p>{t('legal.aviso.datos.denominacion')}: LA MUNTANER TEATRE SL</p>
    <p>{t('legal.aviso.datos.comercial')}: TEATRE MUNTANER</p>
    <p>{t('legal.aviso.datos.domicilio')}: C/ Sodio 2, B6B, (28045)</p>
    <p>CIF: B-55438550</p>
    <p>{t('legal.aviso.datos.email')}: info@teatremuntaner.com</p>
    <p>{t('legal.aviso.terminos.titulo')}</p>
    <p>{t('legal.aviso.p1', { email: EMAIL })}</p>
    <p>{t('legal.aviso.p2', { web: WEB })}</p>
    <p>{t('legal.aviso.p3')}</p>
    <ul>
      <li>{t('legal.aviso.p3-1')}</li>
      <li>{t('legal.aviso.p3-2')}</li>
      <li>{t('legal.aviso.p3-3')}</li>
    </ul>
    <p>{t('legal.aviso.p3-4', { web: WEB })}</p>
    <p>{t('legal.aviso.p3-5', { teatro: TEATRO })}</p>
    <p>{t('legal.aviso.p3-6', { web: WEB })}</p>
    <p>{t('legal.aviso.p3-7')}</p>
    <p>{t('legal.aviso.p4')}</p>
    <p>{t('legal.aviso.p5')}</p>
    <p>{t('legal.aviso.p6')}</p>
    <p>{t('legal.aviso.p7')}</p>
    <p>{t('legal.aviso.p8')}</p>
    <p>{t('legal.aviso.p9')}</p>
    <p>{t('legal.aviso.p10')}</p>
    <p>{t('legal.aviso.p11')}</p>
    <p>{t('legal.aviso.p12')}</p>
    <p>{t('legal.aviso.p13')}</p>
    <p>{t('legal.aviso.p14')}</p>
    <p>{t('legal.aviso.p15')}</p>
    <p>{t('legal.aviso.p16')}</p>
    <p>{t('legal.aviso.p17')}</p>
  </article>
</BaseLayout>

<style>
  .legal { max-width: 820px; margin: 0 auto; padding: clamp(40px, 7vw, 90px) 20px; }
  .legal h1 { font-size: clamp(30px, 5vw, 50px); line-height: 1.1; margin-bottom: 28px; }
  .legal h2 { font-family: var(--f-display); font-size: 20px; letter-spacing: 0.02em; color: var(--accent); margin: 34px 0 10px; }
  .legal p, .legal li { color: var(--paper-dim); line-height: 1.75; margin: 10px 0; font-size: 16px; }
  .legal ul { padding-left: 22px; }
  .legal a { color: var(--accent); }
</style>
