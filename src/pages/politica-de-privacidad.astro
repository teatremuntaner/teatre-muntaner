---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useT, langFromPath } from '../i18n';

const lang = langFromPath(Astro.url.pathname);
const t = useT(lang);

// Nombre propio, razon social y dominio: NO se traducen, entran como variable.
const TEATRO = 'Teatre Muntaner';
const EMPRESA = 'LA MUNTANER TEATRE SL';
const WEB = 'www.teatremuntaner.com';
---
<BaseLayout title={t('legal.privacidad.meta.titulo')} description={t('legal.privacidad.meta.descripcion', { teatro: TEATRO })}>
  <article class="legal">
    <h1>{t('legal.privacidad.titulo')}</h1>
    <p>{t('legal.privacidad.h.proteccion')}</p>
    <p>{t('legal.privacidad.p1', { web: WEB, empresa: EMPRESA })}</p>
    <p>{t('legal.privacidad.p2', { empresa: EMPRESA })}</p>
    <p>{t('legal.privacidad.p3')}</p>
    <p>{t('legal.privacidad.p4')}</p>
    <p>{t('legal.privacidad.datos.promotor')}:</p>
    <p>{t('legal.privacidad.datos.denominacion')}: LA MUNTANER TEATRE SL</p>
    <p>{t('legal.privacidad.datos.comercial')}: LA MUNTANER TEATRE</p>
    <p>{t('legal.privacidad.datos.domicilio')}: C/ Sodio 2, B6B, (28045)</p>
    <p>CIF: B-55438550</p>
    <p>{t('legal.privacidad.datos.email')}: info@teatremuntaner.com</p>
  </article>
</BaseLayout>

<style>
  .legal { max-width: 820px; margin: 0 auto; padding: clamp(40px, 7vw, 90px) 20px; }
  .legal h1 { font-size: clamp(30px, 5vw, 50px); line-height: 1.1; margin-bottom: 28px; }
  .legal h2 { font-family: var(--f-display); font-size: 20px; letter-spacing: 0.02em; color: var(--accent); margin: 34px 0 10px; }
  .legal p, .legal li { color: var(--paper-dim); line-height: 1.75; margin: 10px 0; font-size: 16px; }
  .legal ul { padding-left: 22px; }
  .legal a { color: var(--accent); }
</style>
