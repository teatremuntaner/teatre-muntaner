---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useT, langFromPath } from '../i18n';

const lang = langFromPath(Astro.url.pathname);
const t = useT(lang);
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={t('aviso.meta.titulo')} description={t('aviso.meta.descripcion')}>
  <section class="ok">
    <p class="ok__big" aria-hidden="true">✓</p>
    <h1>{t('aviso.titulo')}</h1>
    <p class="ok__lead">{t('aviso.lead')}</p>
    <div class="ok__cta">
      <a class="btn btn--accent" href={base}>{t('aviso.cta.inicio')}</a>
      <a class="btn btn--ghost" href={`${base}#cartelera`}>{t('aviso.cta.cartelera')}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .ok { max-width: 640px; margin: 0 auto; padding: clamp(60px, 12vw, 150px) 20px; text-align: center; }
  .ok__big { font-size: clamp(60px, 12vw, 120px); line-height: 1; color: var(--accent); margin: 0; }
  .ok h1 { font-size: clamp(28px, 5vw, 48px); margin: 6px 0 14px; }
  .ok__lead { color: var(--paper-dim); font-size: 18px; line-height: 1.6; max-width: 46ch; margin: 0 auto; }
  .ok__cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 30px; }
</style>
