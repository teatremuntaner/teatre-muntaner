---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useT, langFromPath } from '../i18n';

const lang = langFromPath(Astro.url.pathname);
const t = useT(lang);

// Nombres propios y de terceros: NO se traducen, entran como variable.
const TEATRO = 'Teatre Muntaner';
const GTM = 'GTM';
const ANALYTICS = 'Google Analytics';
const PROVEEDOR = 'Google LCC';
---
<BaseLayout title={t('legal.cookies.meta.titulo')} description={t('legal.cookies.meta.descripcion', { teatro: TEATRO })}>
  <article class="legal">
    <h1>{t('legal.cookies.titulo')}</h1>
    <h2>{t('legal.cookies.h.que-son')}</h2>
    <p>{t('legal.cookies.p1')}</p>
    <p>{t('legal.cookies.h.definiciones')}</p>
    <ul>
      <li>{t('legal.cookies.def.dato')}</li>
      <li>{t('legal.cookies.def.agregada')}</li>
      <li>{t('legal.cookies.def.equipo')}</li>
      <li>{t('legal.cookies.def.editor')}</li>
      <li>{t('legal.cookies.def.tercero')}</li>
      <li>{t('legal.cookies.def.responsable')}</li>
      <li>{t('legal.cookies.def.habitos')}</li>
    </ul>
    <p>{t('legal.cookies.h.tipos')}</p>
    <p>{t('legal.cookies.p2')}</p>
    <p>{t('legal.cookies.p3')}</p>
    <p>{t('legal.cookies.p4')}</p>
    <p>{t('legal.cookies.p5')}</p>
    <p>{t('legal.cookies.p6')}</p>
    <p>{t('legal.cookies.p7')}</p>
    <p>{t('legal.cookies.p8')}</p>
    <p>{t('legal.cookies.p9')}</p>
    <p>{t('legal.cookies.p10')}</p>
    <p>{t('legal.cookies.p11')}</p>
    <p>{t('legal.cookies.p12')}</p>
    <p>{t('legal.cookies.p13')}</p>
    <p>{t('legal.cookies.h.concreto')}</p>
    <p>{t('legal.cookies.p14', { gtm: GTM })}</p>
    <p>{t('legal.cookies.p15')}</p>
    <p>{t('legal.cookies.p16', { gtm: GTM, analytics: ANALYTICS, proveedor: PROVEEDOR })}</p>
    <p>{t('legal.cookies.p17')}</p>
    <p>{t('legal.cookies.h.desactivar')}</p>
    <p>{t('legal.cookies.p18')}</p>
    <p>{t('legal.cookies.p19')}</p>
    <p>{t('legal.cookies.p20')}</p>
  </article>
</BaseLayout>

<style>
  .legal { max-width: 820px; margin: 0 auto; padding: clamp(40px, 7vw, 90px) 20px; }
  .legal h1 { font-size: clamp(30px, 5vw, 50px); line-height: 1.1; margin-bottom: 28px; }
  .legal h2 { font-family: var(--f-display); font-size: 20px; letter-spacing: 0.02em; color: var(--accent); margin: 34px 0 10px; }
  .legal p, .legal li { color: var(--paper-dim); line-height: 1.75; margin: 10px 0; font-size: 16px; }
  .legal ul { padding-left: 22px; }
  .legal a { color: var(--accent); }
</style>
