---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useT, langFromPath } from '../i18n';

const lang = langFromPath(Astro.url.pathname);
const t = useT(lang);
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={t('e404.meta.titulo')} description={t('e404.meta.descripcion')}>
  <section class="nf">
    <p class="nf__big" aria-hidden="true">404</p>
    <h1>{t('e404.titulo')}</h1>
    <p class="nf__lead">{t('e404.lead')}</p>
    <div class="nf__cta">
      <a class="btn btn--accent" href={base}>{t('e404.cta.inicio')}</a>
      <a class="btn btn--ghost" href={`${base}#cartelera`}>{t('e404.cta.cartelera')}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { max-width: 680px; margin: 0 auto; padding: clamp(60px, 12vw, 150px) 20px; text-align: center; }
  .nf__big { font-family: var(--f-display); font-weight: 700; font-size: clamp(90px, 20vw, 220px); line-height: 1; color: var(--accent); margin: 0; letter-spacing: 0.02em; }
  .nf h1 { font-size: clamp(28px, 5vw, 48px); margin: 6px 0 14px; }
  .nf__lead { color: var(--paper-dim); font-size: 18px; line-height: 1.6; max-width: 46ch; margin: 0 auto; }
  .nf__cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }
</style>
